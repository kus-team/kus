# Скопируй в backend/.env и заполни.
# Для Neon free tier: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/kus?sslmode=require

# Курс UZS→USD на момент демо (можно переопределить)
UZS_PER_USD=12500

# egov.uz базовый URL — менять не надо
EGOV_BASE=https://data.egov.uz

# Anthropic API key для AI-narrative («объясни тендер простым языком»)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# (опционально) Perplexity для обогащения данных о компаниях из открытых источников
PERPLEXITY_API_KEY=
